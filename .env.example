# ---------------------------------------------------------------
# LumpuFarm Publisher — environment configuration
# Copy this file to .env and adjust the values.
# ---------------------------------------------------------------

# HTTP port the API listens on
PORT=3000

# Timezone used for generated filenames (2026-07-16-0630.png)
TZ=Asia/Bangkok

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: use a system Chromium instead of the bundled Playwright
# browser (leave empty inside the official Docker image)
CHROMIUM_EXECUTABLE_PATH=

# ---------------------------------------------------------------
# Facebook Graph API (future integration — optional)
# When both values are set, POST /publish/facebook becomes active.
# ---------------------------------------------------------------
FB_PAGE_ID=
FB_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0
